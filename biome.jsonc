{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "files": {
    "includes": [
      "!**/dist/**",
      "!**/storybook-static/**",
      "!**/node_modules/**",
      "apps/*/src/**/*.ts",
      "apps/*/src/**/*.tsx",
      "apps/*/src/**/*.js",
      "apps/*/src/**/*.jsx",
      "apps/*/package.json",
      "packages/*/src/**/*.ts",
      "packages/*/src/**/*.tsx",
      "packages/*/src/**/*.js",
      "packages/*/src/**/*.jsx",
      "packages/*/package.json",
      "package.json",
      "vite.config.ts"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noDebugger": "error",
        "noDoubleEquals": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  }
}
