{
  "name": "borg",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:web",
    "build:storybook": "storybook build -c packages/borg-ui/.storybook -o packages/borg-ui/storybook-static",
    "build:web": "bun run vite build",
    "check": "biome check --formatter-enabled=true --linter-enabled=false ./packages",
    "dev": "bun run vite",
    "fix": "biome check --formatter-enabled=true --linter-enabled=true --write ./packages",
    "format": "biome format --write ./packages",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false ./packages",
    "lint": "biome lint --diagnostic-level=error ./packages",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006 -c packages/borg-ui/.storybook",
    "test": "bun test ./packages --pass-with-no-tests",
    "test:e2e": "playwright test",
    "test:ui": "vitest --config packages/borg-ui/vitest.config.ts --run",
    "test:storybook": "vitest --config vite.config.ts --project storybook --run --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@iconify/react": "^5.2.1",
    "@icons-pack/react-simple-icons": "^12.9.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.474.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^6.30.3",
    "reactflow": "^11.11.4",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@frontman-ai/vite": "^0.2.6",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.13",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
