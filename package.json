{
  "name": "borg-web-monorepo",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run vite",
    "build:web": "bun run vite build",
    "storybook": "storybook dev -p 6006 -c packages/borg-ui/.storybook",
    "build:storybook": "storybook build -c packages/borg-ui/.storybook -o packages/borg-ui/storybook-static",
    "test": "bun test --pass-with-no-tests",
    "test:storybook": "vitest --config vite.config.ts --project storybook --run --passWithNoTests",
    "check": "bun run build:web",
    "build:rust": "cargo build -p borg-cli",
    "build": "bun run build:web && bun run build:rust",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@iconify/react": "^5.2.1",
    "@icons-pack/react-simple-icons": "^12.9.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/vite": "^4.1.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "effect": "^3.13.5",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.474.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^6.30.1",
    "reactflow": "^11.11.4",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@frontman-ai/vite": "^0.2.6",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "storybook": "^10.2.13",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
