# Logging
RUST_LOG=info,borg_cli=debug,borg_api=debug,borg_ports=debug,borg_db=debug,borg_exec=debug,borg_memory=debug,borg_codemode=debug

# Frontend API base URL used at build time (REST + GraphQL).
# Example: http://localhost:8080
BORG_API=

# OpenAI device code / sign-in (optional)
# Set this if you want "Sign in with OpenAI" flows enabled.
BORG_OPENAI_OAUTH_CLIENT_ID=

# Optional overrides for OpenAI device-code endpoint behavior.
BORG_OPENAI_DEVICE_CODE_URL=https://auth.openai.com/oauth/device/code
BORG_OPENAI_DEVICE_CODE_SCOPE=openid profile email offline_access

# GitHub OAuth app credentials (required for GitHub app connect/disconnect flow).
# client_id has a default baked in, but you can override it here.
BORG_GITHUB_OAUTH_CLIENT_ID=Ov23lixRdrrvUNKtXcPO
BORG_GITHUB_OAUTH_CLIENT_SECRET=

# Optional provider keys (these are usually configured via API/UI and persisted in config.db).
OPENAI_API_KEY=
OPENROUTER_API_KEY=
